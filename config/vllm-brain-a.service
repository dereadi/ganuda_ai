[Unit]
Description=Qwen3.6 Brain-A (Perceiver) — Vision, Spatial Intelligence, Game State
After=network.target

[Service]
Type=simple
User=dereadi
Group=dereadi
WorkingDirectory=/home/dereadi
Environment=PATH=/home/dereadi/cherokee_venv/bin:/usr/bin:/bin
Environment=HF_HOME=/ganuda/home/dereadi/.cache/huggingface
Environment=CUDA_HOME=/ganuda/cuda-12.8
Environment=LD_LIBRARY_PATH=/ganuda/cuda-12.8/lib64:/ganuda/cuda-12.8/lib
ExecStart=/home/dereadi/cherokee_venv/bin/python -m vllm.entrypoints.openai.api_server \
  --model Qwen/Qwen3.6-35B-A3B \
  --port 8000 \
  --dtype bfloat16 \
  --gpu-memory-utilization 0.76 \
  --max-model-len 16384 \
  --max-num-seqs 64 \
  --served-model-name /ganuda/models/qwen2.5-72b-instruct-awq Qwen/Qwen3.6-35B-A3B \
  --enable-prefix-caching \
  --attention-backend TRITON_ATTN \
  --trust-remote-code
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vllm-brain-a

[Install]
WantedBy=multi-user.target
